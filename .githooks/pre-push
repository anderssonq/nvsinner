#!/usr/bin/env bash
set -euo pipefail

# Pre-push gate: format check (stylua) + test suite (make test). ~20s total.
#
# Mirrors what .github/workflows/ci.yml enforces, so a red CI is caught here
# instead of after the push. Only runs when the push actually touches Lua.
#
# Skip once:                git push --no-verify
# Disable for this repo:    git config --unset core.hooksPath

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Every tracked *.lua lives under one of these (after/ftplugin/markdown.lua is
# why `after` is here — it is easy to miss).
LUA_PATHS=(init.lua colors lua tests after)

# Nothing to check when the push carries no Lua. `@{u}` is unset for a brand-new
# branch, so fall back to origin/main.
REMOTE_REF="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo 'origin/main')"
# --quiet exits 0 when there is NO diff. An unresolvable ref errors non-zero,
# which falls through to running the checks — fail toward checking, not skipping.
if git diff --quiet "$REMOTE_REF"...HEAD -- '*.lua' 2>/dev/null; then
  echo "[pre-push] No .lua changes to check, skipping."
  exit 0
fi

fail() {
  echo ""
  echo "❌ [pre-push] $1"
  echo "   Skip once (not recommended): git push --no-verify"
  exit 1
}

# ── 1. Format ────────────────────────────────────────────────────────────────
# No .stylua.toml on purpose: stylua's defaults (tabs, 120 cols) already match
# the house style, and none-ls formats on save with those same defaults.
if command -v stylua > /dev/null 2>&1; then
  echo "[pre-push] stylua --check…"
  if ! stylua --check "${LUA_PATHS[@]}"; then
    fail "Formatting drift. Fix it with:  stylua ${LUA_PATHS[*]}"
  fi
  echo "[pre-push] format OK"
else
  # Not fatal: stylua is Mason-installed (lua/plugins/lsp/mason-tools.lua) and
  # may be missing on a fresh clone. CI still enforces the suite.
  echo "[pre-push] stylua not found — skipping format check."
fi

# ── 2. Tests ─────────────────────────────────────────────────────────────────
# Quiet on success (275 passing lines is noise); the full output is printed only
# when something breaks, which is when you actually want it.
echo "[pre-push] make test…"
TEST_LOG="$(mktemp)"
trap 'rm -f "$TEST_LOG"' EXIT

if ! make test > "$TEST_LOG" 2>&1; then
  cat "$TEST_LOG"
  fail "Test suite failed."
fi

# plenary reports failures in its own summary; `make test` exits non-zero too
# (verified: exit 2 on a failing spec), so the exit check above is the gate and
# this is just the human-readable tally.
sed 's/\x1b\[[0-9;]*m//g' "$TEST_LOG" | awk '
  /^Success: / { s += $2 } /^Failed : / { f += $3 } /^Errors : / { e += $3 }
  END { printf "[pre-push] tests: %d passed, %d failed, %d errors\n", s, f, e }'

echo "✅ [pre-push] All good."
