#!/usr/bin/env bash
set -euo pipefail

# Skip the pre-push review by passing the --skip-review push option:
#   git push -o --skip-review
# Alternatively, disable the hook entirely: git push --no-verify

for ((i = 0; i < GIT_PUSH_OPTION_COUNT; i++)); do
  opt="GIT_PUSH_OPTION_$i"
  if [ "${!opt}" = "skip-review" ] || [ "${!opt}" = "--skip-review" ]; then
    echo "[pre-push] Skipped via --skip-review push option."
    exit 0
  fi
done

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROMPT_FILE="$REPO_ROOT/.claude/prompts/pre-push-review.md"
LOG_DIR="$REPO_ROOT/.claude/logs"
LOG_FILE="$LOG_DIR/pre-push-$(date +%Y%m%d-%H%M%S).json"

mkdir -p "$LOG_DIR"

REMOTE_REF="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo 'origin/main')"
DIFF="$(git diff "$REMOTE_REF"...HEAD -- '*.lua' 'CLAUDE.md' 2>/dev/null || true)"

if [ -z "$DIFF" ]; then
  echo "[pre-push] No .lua changes to review, skipping."
  exit 0
fi

if ! command -v claude &> /dev/null; then
  echo "[pre-push] claude CLI not found, skipping review (push not blocked)."
  exit 0
fi

echo "[pre-push] Running review with Claude Code..."
echo "[pre-push] (to skip: git push -o --skip-review, or git push --no-verify)"

if ! RESULT="$(
  claude -p "$(cat "$PROMPT_FILE")

## Diff to review

\`\`\`diff
$DIFF
\`\`\`" \
    --allowedTools "Read" "Grep" "Glob" \
    --permission-mode plan \
    --output-format json \
    --max-turns 6 2>&1
)"; then
  echo ""
  echo "âťŚ [pre-push] claude CLI failed â€” push NOT blocked, but no review ran."
  echo "   To retry the push anyway: just push again."
  echo "   To force-review later: run 'claude' manually, or remove the hook with:"
  echo "     git push --no-verify   # skip this once"
  echo "   To disable the hook for this repo:"
  echo "     git config --unset core.hooksPath"
  exit 0
fi

echo "$RESULT" > "$LOG_FILE"

REVIEW_JSON="$(echo "$RESULT" | python3 -c '
import json, sys, re
try:
    data = json.load(sys.stdin)
    text = data.get("result", "")
    match = re.search(r"\{.*\}", text, re.DOTALL)
    print(match.group(0) if match else "{}")
except Exception:
    print("{}")
')"

VERDICT="$(echo "$REVIEW_JSON" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("verdict","warn"))' 2>/dev/null || echo "warn")"
SUMMARY="$(echo "$REVIEW_JSON" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("summary",""))' 2>/dev/null || echo "")"

echo ""
echo "[pre-push] Verdict: $VERDICT"
echo "[pre-push] $SUMMARY"
echo "[pre-push] Full report: $LOG_FILE"
echo ""

case "$VERDICT" in
  block)
    echo ""
    echo "âťŚ [pre-push] Push blocked â€” critical findings."
    echo "   See report: $LOG_FILE"
    echo ""
    echo "   How to proceed:"
    echo "     1. Fix the findings above, then re-push as usual."
    echo "     2. Skip review once (keeps findings log):  git push -o --skip-review"
    echo "     3. Bypass hook entirely (not recommended): git push --no-verify"
    echo "     4. Disable the hook for this repo:         git config --unset core.hooksPath"
    exit 1
    ;;
  warn)
    echo "âš ď¸Ź  Push allowed, but warnings. See $LOG_FILE"
    exit 0
    ;;
  *)
    echo "âś… All good."
    exit 0
    ;;
esac