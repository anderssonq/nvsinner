# Ignore macOS Finder metadata
.DS_Store

# Ignore swap files
*.swp
*.swo

# Ignore backup files
*~

# Ignore undo history files
*.un~

# Ignore session files
Session.vim

session/
*.vim
# Ignore plugin download directories
plugged/
pack/*/start/*
pack/*/opt/*

# Ignore .netrwhist (netrw plugin history)
.netrwhist

# Ignore coc.nvim extensions
coc/extensions

# Ignore node_modules (for plugins using npm)
node_modules/

# Ignore log files
log/

# Ignore custom cache directories
.cache/
.tmp/


# Testing files
test.js
test.ts


# NvSinner per-user settings cache (:NvSinnerMenu) — settings/prompts.json IS committed
settings/nvsinner-settings.json

# Pre-push review reports (git hook output)
.claude/logs/

# Sinscribe per-feature agent prompt (generated per branch, never committed)
AGENT_PROMPT.md
